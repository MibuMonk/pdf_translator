{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa_report.schema.json",
  "description": "Output of qa_agent. Quality assessment of translated.json.",
  "type": "object",
  "required": ["version", "summary", "issues", "self_eval"],
  "properties": {
    "version": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total_blocks", "translated_blocks", "coverage_pct", "issue_count", "pass"],
      "properties": {
        "total_blocks":      { "type": "integer" },
        "translated_blocks": { "type": "integer" },
        "coverage_pct":      { "type": "number", "minimum": 0, "maximum": 100 },
        "issue_count":       { "type": "integer" },
        "pass":              { "type": "boolean", "description": "True if coverage_pct >= 95" }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "block_id", "type", "severity", "text", "translated"],
        "properties": {
          "page":       { "type": "integer" },
          "block_id":   { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["missing_translation", "unchanged_translation", "likely_truncated", "suspiciously_short"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning"]
          },
          "text":       { "type": "string" },
          "translated": { "type": "string" }
        }
      }
    },
    "self_eval": {
      "type": "object",
      "required": ["retry_candidates", "confidence"],
      "properties": {
        "retry_candidates": {
          "type": "array",
          "description": "block_ids that qa_agent recommends re-translating.",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Self-assessed report reliability."
        }
      }
    }
  }
}
