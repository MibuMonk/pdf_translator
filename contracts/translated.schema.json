{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "translated.schema.json",
  "description": "Output of translate_agent. Extends parsed.schema.json — every block gains a 'translated' field.",
  "allOf": [
    { "$ref": "parsed.schema.json" },
    {
      "type": "object",
      "properties": {
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "blocks": {
                "type": "array",
                "items": { "$ref": "#/$defs/translated_block" }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "translated_block": {
      "type": "object",
      "required": ["translated"],
      "properties": {
        "translated": {
          "type": "string",
          "description": "Translated text. Empty string if translation failed. MUST preserve \\n structure."
        },
        "translated_spans": {
          "type": "array",
          "description": "Per-span translated text with color, produced for multi-color blocks. Optional.",
          "items": {
            "type": "object",
            "required": ["text", "color"],
            "properties": {
              "text": { "type": "string" },
              "color": {
                "type": "array",
                "items": { "type": "number", "minimum": 0, "maximum": 1 },
                "minItems": 3,
                "maxItems": 3
              }
            }
          }
        }
      }
    }
  }
}
