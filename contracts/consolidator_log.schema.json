{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "consolidator_log.schema.json",
  "description": "Self-evaluation log output by consolidator. Used for self-iteration and intel review.",
  "type": "object",
  "required": ["version", "total_before", "total_after", "merges", "skipped", "self_eval"],
  "properties": {
    "version":       { "type": "string" },
    "total_before":  { "type": "integer" },
    "total_after":   { "type": "integer" },
    "merges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "absorbed", "into", "reason"],
        "properties": {
          "page":     { "type": "integer" },
          "absorbed": { "type": "array", "items": { "type": "string" } },
          "into":     { "type": "string" },
          "reason":   { "type": "string" }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "block_id", "reason"],
        "properties": {
          "page":     { "type": "integer" },
          "block_id": { "type": "string" },
          "reason":   { "type": "string" }
        }
      }
    },
    "self_eval": {
      "type": "object",
      "required": ["suspected_table_pages", "missed_fragment_candidates", "confidence"],
      "description": "Consolidator's own assessment of its output quality.",
      "properties": {
        "suspected_table_pages": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Pages where table structure was detected and merging was suppressed."
        },
        "missed_fragment_candidates": {
          "type": "array",
          "description": "Block pairs that look like fragments but were NOT merged (e.g. x_diff too large).",
          "items": {
            "type": "object",
            "properties": {
              "page":     { "type": "integer" },
              "block_a":  { "type": "string" },
              "block_b":  { "type": "string" },
              "reason":   { "type": "string" }
            }
          }
        },
        "confidence": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Self-assessed merge quality. 1.0 = fully confident, 0.0 = very uncertain."
        }
      }
    }
  }
}
